/* 山中一甲子 - 游戏样式 */

:root {
    /* 颜色主题 - 基于五行 */
    --wood-color: #4CAF50;
    --fire-color: #FF5722;
    --earth-color: #795548;
    --metal-color: #607D8B;
    --water-color: #2196F3;
    
    /* 基础颜色 - 天蓝色主题 */
    --bg-primary: #87CEEB;  /* 天蓝色 */
    --bg-secondary: #B0E2FF; /* 浅天蓝色 */
    --bg-card: #FFFFFF;      /* 白色卡片 */
    --text-primary: #333333; /* 深灰色文字 */
    --text-secondary: #666666; /* 中灰色文字 */
    --accent-color: #2196F3;  /* 蓝色强调色 */
    --border-color: #BBDEFB;  /* 浅蓝色边框 */
    
    /* 阴影和效果 */
    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
    
    /* 边框半径 */
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Noto Serif SC', serif;
    background: linear-gradient(135deg, #87CEEB, #B0E2FF); /* 天蓝色渐变 */
    color: var(--text-primary);
    min-height: 100vh;
    line-height: 1.6;
}

.container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px;
}

/* 游戏头部 */
.game-header {
    background: rgba(255, 255, 255, 0.9); /* 白色半透明 */
    border-radius: var(--radius-lg);
    padding: 20px;
    margin-bottom: 20px;
    border: 2px solid var(--border-color);
    box-shadow: var(--shadow-md);
    backdrop-filter: blur(10px);
}

.game-title {
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 2.8rem;
    color: var(--accent-color); /* 蓝色标题 */
    text-align: center;
    margin-bottom: 10px;
    text-shadow: 0 0 10px rgba(33, 150, 243, 0.3); /* 蓝色阴影 */
}

.game-title i {
    margin-right: 15px;
    color: var(--wood-color);
}

.game-stats {
    display: flex;
    justify-content: center;
    gap: 30px;
    font-size: 1.2rem;
}

.time-display, .weather-display {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.8); /* 白色半透明背景 */
    padding: 8px 16px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
}

.time-display i, .weather-display i {
    color: var(--accent-color);
    font-size: 1.4rem;
}

/* 五行区域 */
.five-elements-section {
    background: rgba(255, 255, 255, 0.9); /* 白色半透明 */
    border-radius: var(--radius-lg);
    padding: 25px;
    margin-bottom: 20px;
    border: 2px solid var(--border-color);
    box-shadow: var(--shadow-md);
}

.five-elements-section h2 {
    color: var(--accent-color);
    margin-bottom: 20px;
    font-size: 1.8rem;
    display: flex;
    align-items: center;
    gap: 10px;
}

.elements-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 25px;
}

.element-card {
    background: var(--bg-card);
    border-radius: var(--radius-md);
    padding: 20px;
    text-align: center;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    position: relative;
    overflow: hidden;
}

.element-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
}

.element-card.wood {
    border-color: var(--wood-color);
}

.element-card.fire {
    border-color: var(--fire-color);
}

.element-card.earth {
    border-color: var(--earth-color);
}

.element-card.metal {
    border-color: var(--metal-color);
}

.element-card.water {
    border-color: var(--water-color);
}

.element-icon {
    font-size: 2.5rem;
    margin-bottom: 10px;
    height: 60px;
    width: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 15px;
}

.wood .element-icon {
    background: rgba(76, 175, 80, 0.2);
    color: var(--wood-color);
}

.fire .element-icon {
    background: rgba(255, 87, 34, 0.2);
    color: var(--fire-color);
}

.earth .element-icon {
    background: rgba(121, 85, 72, 0.2);
    color: var(--earth-color);
}

.metal .element-icon {
    background: rgba(96, 125, 139, 0.2);
    color: var(--metal-color);
}

.water .element-icon {
    background: rgba(33, 150, 243, 0.2);
    color: var(--water-color);
}

.element-card h3 {
    font-size: 2rem;
    margin-bottom: 5px;
    font-family: 'Ma Shan Zheng', cursive;
}

.element-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 15px;
}

.element-value {
    font-size: 1.2rem;
    margin-bottom: 10px;
    font-weight: bold;
}

.element-bar {
    height: 8px;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 15px;
}

.element-fill {
    height: 100%;
    transition: width 0.5s ease;
}

.wood .element-fill {
    background: var(--wood-color);
}

.fire .element-fill {
    background: var(--fire-color);
}

.earth .element-fill {
    background: var(--earth-color);
}

.metal .element-fill {
    background: var(--metal-color);
}

.water .element-fill {
    background: var(--water-color);
}

.element-btn {
    width: 100%;
    padding: 10px;
    border: none;
    border-radius: var(--radius-sm);
    font-family: 'Noto Serif SC', serif;
    font-size: 1rem;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.wood .element-btn {
    background: var(--wood-color);
    color: white;
}

.fire .element-btn {
    background: var(--fire-color);
    color: white;
}

.earth .element-btn {
    background: var(--earth-color);
    color: white;
}

.metal .element-btn {
    background: var(--metal-color);
    color: white;
}

.water .element-btn {
    background: var(--water-color);
    color: white;
}

.element-btn:hover {
    opacity: 0.9;
    transform: scale(1.05);
}

.element-btn:active {
    transform: scale(0.95);
}

.balance-indicator {
    background: rgba(255, 255, 255, 0.8); /* 白色半透明 */
    border-radius: var(--radius-md);
    padding: 15px;
    border: 1px solid var(--border-color);
}

.balance-status {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.2rem;
    margin-bottom: 10px;
    color: var(--accent-color);
}

.balance-tip {
    color: var(--text-secondary);
    font-style: italic;
    text-align: center;
}

/* 荒山区 */
.mountain-section {
    background: rgba(255, 255, 255, 0.9); /* 白色半透明 */
    border-radius: var(--radius-lg);
    padding: 25px;
    margin-bottom: 20px;
    border: 2px solid var(--border-color);
    box-shadow: var(--shadow-md);
}

.mountain-section h2 {
    color: var(--accent-color);
    margin-bottom: 20px;
    font-size: 1.8rem;
    display: flex;
    align-items: center;
    gap: 10px;
}

.mountain-display {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 30px;
}

.mountain-visual {
    background: linear-gradient(to bottom, #87CEEB, #1E90FF); /* 天蓝色到深蓝色渐变 */
    border-radius: var(--radius-md);
    height: 300px;
    position: relative;
    overflow: hidden;
    border: 3px solid var(--accent-color); /* 使用蓝色边框 */
    box-shadow: var(--shadow-lg);
}

.mountain-base {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    background: linear-gradient(to right, #4682B4, #1E90FF, #4682B4); /* 蓝色山脉 */
    clip-path: polygon(0% 100%, 20% 40%, 40% 60%, 60% 30%, 80% 50%, 100% 100%);
}

.mountain-stats {
    background: var(--bg-card);
    border-radius: var(--radius-md);
    padding: 20px;
    border: 2px solid var(--earth-color);
}

.stat-item {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--border-color);
}

.stat-item:last-child {
    border-bottom: none;
}

.stat-label {
    color: var(--text-secondary);
}

.stat-value {
    font-weight: bold;
    color: var(--accent-color);
    font-size: 1.2rem;
}

/* AI对话区 */
.ai-dialogue-section {
    background: rgba(255, 255, 255, 0.9); /* 白色半透明 */
    border-radius: var(--radius-lg);
    padding: 25px;
    margin-bottom: 20px;
    border: 2px solid var(--border-color);
    box-shadow: var(--shadow-md);
}

.ai-dialogue-section h2 {
    color: var(--accent-color);
    margin-bottom: 20px;
    font-size: 1.8rem;
    display: flex;
    align-items: center;
    gap: 10px;
}

.dialogue-container {
    background: var(--bg-card);
    border-radius: var(--radius-md);
    padding: 20px;
    border: 2px solid var(--metal-color);
}

.dialogue-history {
    height: 200px;
    overflow-y: auto;
    margin-bottom: 20px;
    padding: 15px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
}

.dialogue-message {
    margin-bottom: 15px;
    padding: 12px;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.05);
}

.dialogue-message.system {
    border-left: 4px solid var(--accent-color);
}

.message-header {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--accent-color);
    font-weight: bold;
    margin-bottom: 8px;
}

.message-content {
    line-height: 1.5;
}

.dialogue-input textarea {
    width: 100%;
    height: 100px;
    padding: 15px;
    background: rgba(255, 255, 255, 0.9); /* 白色半透明 */
    border: 2px solid var(--border-color);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-family: 'Noto Serif SC', serif;
    font-size: 1rem;
    resize: vertical;
    margin-bottom: 15px;
}

.dialogue-input textarea:focus {
    outline: none;
    border-color: var(--accent-color);
}

.dialogue-actions {
    display: flex;
    gap: 15px;
    margin-bottom: 15px;
}

.primary-btn, .secondary-btn {
    padding: 12px 24px;
    border: none;
    border-radius: var(--radius-sm);
    font-family: 'Noto Serif SC', serif;
    font-size: 1rem;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex: 1;
}

.primary-btn {
    background: var(--water-color);
    color: white;
}

.secondary-btn {
    background: var(--metal-color);
    color: white;
}

.primary-btn:hover, .secondary-btn:hover {
    opacity: 0.9;
    transform: translateY(-2px);
}

.primary-btn:active, .secondary-btn:active {
    transform: translateY(0);
}

.dialogue-tips {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-secondary);
    font-style: italic;
    padding: 10px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: var(--radius-sm);
}

/* 游戏日志区 */
.game-log-section {
    background: rgba(255, 255, 255, 0.9); /* 白色半透明 */
    border-radius: var(--radius-lg);
    padding: 25px;
    margin-bottom: 20px;
    border: 2px solid var(--border-color);
    box-shadow: var(--shadow-md);
}

.game-log-section h2 {
    color: var(--accent-color);
    margin-bottom: 20px;
    font-size: 1.8rem;
    display: flex;
    align-items: center;
    gap: 10px;
}

.log-container {
    background: var(--bg-card);
    border-radius: var(--radius-md);
    padding: 20px;
    border: 2px solid var(--wood-color);
}

.log-entries {
    height: 150px;
    overflow-y: auto;
    margin-bottom: 15px;
    padding: 15px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
}

.log-entry {
    padding: 8px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    gap: 15px;
}

.log-entry:last-child {
    border-bottom: none;
}

.log-time {
    color: var(--accent-color);
    font-weight: bold;
    min-width: 100px;
}

.log-content {
    color: var(--text-secondary);
}

/* 游戏控制区域 */
.game-control-section {
    background: rgba(255, 255, 255, 0.9); /* 白色半透明 */
    border-radius: var(--radius-lg);
    padding: 25px;
    margin-bottom: 20px;
    border: 2px solid var(--border-color);
    box-shadow: var(--shadow-md);
}

.control-panel {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
}

.resource-display {
    display: flex;
    gap: 30px;
    flex-wrap: wrap;
}

.resource-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.1rem;
    background: rgba(255, 255, 255, 0.8); /* 白色半透明 */
    padding: 10px 20px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
}

/* 游戏底部 */
.game-footer {
    background: rgba(255, 255, 255, 0.9); /* 白色半透明 */
    border-radius: var(--radius-lg);
    padding: 20px;
    border: 2px solid var(--border-color);
    box-shadow: var(--shadow-md);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.resource-item i {
    color: var(--accent-color);
    font-size: 1.3rem;
}

.game-controls {
    display: flex;
    gap: 15px;
}

.control-btn {
    padding: 10px 20px;
    background: var(--water-color); /* 蓝色背景 */
    border: 2px solid var(--border-color);
    border-radius: var(--radius-md);
    color: white; /* 白色文字 */
    font-family: 'Noto Serif SC', serif;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
}

.control-btn:hover {
    background: #1976D2; /* 深蓝色悬停 */
    border-color: var(--accent-color);
    transform: translateY(-2px);
}

.control-btn:active {
    transform: translateY(0);
}

/* 模态框 */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    z-index: 1000;
    align-items: center;
    justify-content: center;
}

.modal-content {
    background: white; /* 纯白背景 */
    border-radius: var(--radius-lg);
    width: 90%;
    max-width: 600px;
    max-height: 80vh;
    overflow-y: auto;
    border: 3px solid var(--accent-color);
    box-shadow: var(--shadow-lg);
}

.modal-header {
    background: var(--accent-color); /* 蓝色标题栏 */
    padding: 20px;
    border-bottom: 2px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.modal-header h3 {
    color: white; /* 白色标题文字 */
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    gap: 10px;
}

.close-modal {
    background: none;
    border: none;
    color: var(--text-primary);
    font-size: 2rem;
    cursor: pointer;
    line-height: 1;
    padding: 0 10px;
}

.close-modal:hover {
    color: var(--accent-color);
}

.modal-body {
    padding: 25px;
}

.modal-body h4 {
    color: var(--accent-color);
    margin: 20px 0 10px;
    font-size: 1.3rem;
}

.modal-body p {
    margin-bottom: 15px;
    line-height: 1.6;
}

.modal-body ul {
    list-style: none;
    padding-left: 20px;
}

.modal-body li {
    margin-bottom: 8px;
    padding-left: 10px;
    position: relative;
}

.modal-body li:before {
    content: "•";
    color: var(--accent-color);
    position: absolute;
    left: -10px;
}

/* 响应式设计 */
@media (max-width: 1024px) {
    .mountain-display {
        grid-template-columns: 1fr;
    }
    
    .elements-container {
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }
}

@media (max-width: 768px) {
    .game-footer {
        flex-direction: column;
        gap: 20px;
    }
    
    .control-panel {
        flex-direction: column;
        gap: 20px;
    }
    
    .resource-display {
        flex-direction: column;
        gap: 10px;
        width: 100%;
    }
    
    .game-controls {
        width: 100%;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .elements-container {
        grid-template-columns: 1fr;
    }
    
    .game-stats {
        flex-direction: column;
        gap: 10px;
        align-items: center;
    }
}

/* 自定义滚动条 */
::-webkit-scrollbar {
    width: 10px;
}

::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 5px;
}

::-webkit-scrollbar-thumb {
    background: var(--earth-color);
    border-radius: 5px;
}

::-webkit-scrollbar-thumb:hover {
    background: var(--accent-color);
}

/* 动画 */
@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.element-card, .mountain-section, .ai-dialogue-section, .game-log-section {
    animation: fadeIn 0.5s ease-out;
}

/* 植物和动物样式 */
.plant {
    position: absolute;
    width: 20px;
    height: 30px;
    background: var(--wood-color);
    border-radius: 50% 50% 0 0;
    animation: grow 2s ease-in-out;
}

.animal {
    position: absolute;
    width: 30px;
    height: 30px;
    background: var(--fire-color);
    border-radius: 50%;
    animation: move 5s infinite linear;
}

@keyframes grow {
    from { transform: scale(0); }
    to { transform: scale(1); }
}

@keyframes move {
    0%, 100% { transform: translateX(0) translateY(0); }
    25% { transform: translateX(20px) translateY(-10px); }
    50% { transform: translateX(40px) translateY(0); }
    75% { transform: translateX(20px) translateY(10px); }
}

/* 天气效果 */
.rain {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(transparent 0%, rgba(33, 150, 243, 0.1) 100%);
    animation: rain 1s linear infinite;
    pointer-events: none;
}

.sunshine {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 20%, rgba(255, 87, 34, 0.2), transparent 70%);
    animation: shine 3s ease-in-out infinite;
    pointer-events: none;
}

.wind {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(76, 175, 80, 0.05) 50%, transparent 100%);
    animation: wind 2s linear infinite;
    pointer-events: none;
}

.mist {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(rgba(121, 85, 72, 0.1), transparent 30%);
    animation: mist 5s ease-in-out infinite;
    pointer-events: none;
}

.clear {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 70% 30%, rgba(96, 125, 139, 0.1), transparent 60%);
    animation: clear 4s ease-in-out infinite;
    pointer-events: none;
}

.balanced {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: conic-gradient(
        from 0deg at 50% 50%,
        rgba(76, 175, 80, 0.05) 0deg,
        rgba(255, 87, 34, 0.05) 72deg,
        rgba(121, 85, 72, 0.05) 144deg,
        rgba(96, 125, 139, 0.05) 216deg,
        rgba(33, 150, 243, 0.05) 288deg,
        rgba(76, 175, 80, 0.05) 360deg
    );
    animation: rotate 20s linear infinite;
    pointer-events: none;
}

@keyframes rain {
    0% { background-position: 0% 0%; }
    100% { background-position: 0% 100%; }
}

@keyframes shine {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.05); }
}

@keyframes wind {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}

@keyframes mist {
    0%, 100% { opacity: 0.1; }
    50% { opacity: 0.3; }
}

@keyframes clear {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0.4; }
}

@keyframes rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* 粒子效果 */
.particle {
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
}

.wood-particle {
    background: var(--wood-color);
    animation: float-wood 3s ease-in-out infinite;
}

.fire-particle {
    background: var(--fire-color);
    animation: float-fire 2s ease-in-out infinite;
}

.earth-particle {
    background: var(--earth-color);
    animation: float-earth 4s ease-in-out infinite;
}

.metal-particle {
    background: var(--metal-color);
    animation: float-metal 3.5s ease-in-out infinite;
}

.water-particle {
    background: var(--water-color);
    animation: float-water 2.5s ease-in-out infinite;
}

@keyframes float-wood {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.3; }
    50% { transform: translate(10px, -20px) scale(1.2); opacity: 0.6; }
}

@keyframes float-fire {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
    50% { transform: translate(-15px, -15px) scale(1.3); opacity: 0.8; }
}

@keyframes float-earth {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.2; }
    50% { transform: translate(5px, 10px) scale(1.1); opacity: 0.5; }
}

@keyframes float-metal {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.3; }
    50% { transform: translate(-10px, 5px) scale(1.15); opacity: 0.6; }
}

@keyframes float-water {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
    50% { transform: translate(15px, -10px) scale(1.25); opacity: 0.7; }
}

/* 元素激活效果 */
.element-card.active {
    box-shadow: 0 0 20px currentColor;
    transform: translateY(-5px);
}

.element-card.active .element-icon {
    animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
}

/* 成就闪光效果 */
.achievement-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at center, rgba(255, 213, 79, 0.3), transparent 70%);
    animation: glow 2s ease-out;
    pointer-events: none;
}

@keyframes glow {
    0% { opacity: 0; transform: scale(0.5); }
    50% { opacity: 1; transform: scale(1.2); }
    100% { opacity: 0; transform: scale(1.5); }
}